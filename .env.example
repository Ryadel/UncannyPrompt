COMPOSE_PROJECT_NAME=uncannyprompt

DOTNET_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

Docker__WebAppPort=8080
Docker__WebAppContainerPort=8080
Docker__SqlServerPublicPort=1433
Docker__SqlServerContainerPort=1433

Database__Host=sqlserver
Database__Port=1433
Database__Name=UncannyPrompt
Database__Username=sa
Database__Password=Your_password123
Database__TrustServerCertificate=true
# Database__ApplyMigrationsOnStartup=true  # default: true in Development, false otherwise

Security__SecretEncryptionKey=replace-with-a-long-random-value
Security__ApiKeyHashKey=replace-with-a-long-random-value

Authentication__Google__ClientId=
Authentication__Google__ClientSecret=

Authentication__EntraId__Instance=https://login.microsoftonline.com/
Authentication__EntraId__TenantId=
Authentication__EntraId__ClientId=
Authentication__EntraId__ClientSecret=
Authentication__EntraId__CallbackPath=/signin-oidc

Authentication__GitHub__ClientId=
Authentication__GitHub__ClientSecret=

# SeedOptions__AdminUsers__0__Provider=EntraId
# SeedOptions__AdminUsers__0__UniqueId=00000000-0000-0000-0000-000000000000
# SeedOptions__AdminUsers__0__Email=admin@example.com
