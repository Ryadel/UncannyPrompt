# UncannyPrompt Docker/default environment variables (.env)
#
# Purpose: provide the default developer stack configuration used by
# docker-compose.yml and by the application before optional local overrides.
#
# Convention:
#   App configuration variables mirror appsettings keys, using `__` (double
#   underscore) as the hierarchical separator.
#   Example: appsettings key `Database:Host` -> env var `Database__Host`.
#
# Override chain for dotnet run / IDE:
#   appsettings.json -> .env -> .env.local -> process environment
#
# Docker Compose reads this file automatically. Keep values here suitable for
# the Docker network. Put host-local overrides in .env.local.

COMPOSE_PROJECT_NAME=uncannyprompt

# --- .NET / ASP.NET Core ---
DOTNET_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# --- Docker Compose published ports / container-only knobs ---
Docker__WebAppPort=8080
Docker__WebAppContainerPort=8080
Docker__SqlServerPublicPort=1433
Docker__SqlServerContainerPort=1433

# --- Database (SQL Server) ---
# Default local Docker setup:
#   Keep Database__Username=sa. The SQL Server container bootstraps the built-in
#   sa login automatically via MSSQL_SA_PASSWORD, which docker-compose.yml maps
#   from Database__Password.
# Shared or managed SQL Server setup:
#   Create your application login/user manually on that instance, then replace
#   Database__Username and Database__Password with those dedicated credentials.
Database__Host=sqlserver
Database__Port=1433
Database__Name=UncannyPrompt
Database__Username=sa
Database__Password=Your_password123
Database__TrustServerCertificate=true
# Database__ApplyMigrationsOnStartup=true  # default: true in Development, false otherwise

# --- Security secrets ---
Security__SecretEncryptionKey=replace-with-a-long-random-value
Security__ApiKeyHashKey=replace-with-a-long-random-value

# --- Google OAuth ---
Authentication__Google__ClientId=
Authentication__Google__ClientSecret=

# --- Microsoft Entra ID ---
Authentication__EntraId__Instance=https://login.microsoftonline.com/
Authentication__EntraId__TenantId=
Authentication__EntraId__ClientId=
Authentication__EntraId__ClientSecret=
Authentication__EntraId__CallbackPath=/signin-oidc

# --- GitHub OAuth ---
Authentication__GitHub__ClientId=
Authentication__GitHub__ClientSecret=

# --- Optional: seed admin users on startup ---
# SeedOptions__AdminUsers__0__Provider=EntraId
# SeedOptions__AdminUsers__0__UniqueId=00000000-0000-0000-0000-000000000000
# SeedOptions__AdminUsers__0__Email=admin@example.com
