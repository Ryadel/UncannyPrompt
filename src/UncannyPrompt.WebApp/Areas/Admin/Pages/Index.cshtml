@page
@model IndexModel
@{
    ViewData["Title"] = Localizer["PageTitle"];
}

<section class="app-page">
    <partial name="_AppPageHeader" model="@(new AppPageHeaderModel(Localizer["PageTitle"].Value))" />

    <div class="app-page-grid">
        <div class="app-page-main space-y-4 lg:col-span-2">
            <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
                <article class="app-stat"><p class="app-stat-label">@Localizer["Users"]</p><p class="app-stat-value">@Model.Dashboard.UserCount</p></article>
                <article class="app-stat"><p class="app-stat-label">@Localizer["ActiveUsers"]</p><p class="app-stat-value">@Model.Dashboard.ActiveUserCount</p></article>
                <article class="app-stat"><p class="app-stat-label">@Localizer["Tenants"]</p><p class="app-stat-value">@Model.Dashboard.TenantCount</p></article>
                <article class="app-stat"><p class="app-stat-label">@Localizer["Workspaces"]</p><p class="app-stat-value">@Model.Dashboard.WorkspaceCount</p></article>
                <article class="app-stat"><p class="app-stat-label">@Localizer["Projects"]</p><p class="app-stat-value">@Model.Dashboard.ProjectCount</p></article>
                <article class="app-stat"><p class="app-stat-label">@Localizer["Prompts"]</p><p class="app-stat-value">@Model.Dashboard.PromptCount</p></article>
            </div>

            <article class="app-card">
                <div class="app-card-body">
                    <div class="app-list-item-header">
                        <h2 class="app-list-item-title">@Localizer["RecentUsers"]</h2>
                        <a class="btn btn-outline btn-sm rounded-lg" asp-area="Admin" asp-page="/Users/Index">@Localizer["ManageUsers"]</a>
                    </div>
                    <div class="mt-4 grid gap-2">
                        @foreach (var user in Model.Dashboard.RecentUsers)
                        {
                            <div class="app-row-item">
                                <div>
                                    <div class="app-row-item-title">@user.DisplayName</div>
                                    <div class="app-row-item-subtitle">@user.Email</div>
                                </div>
                                <div class="flex gap-2">
                                    <span class="badge rounded-md">@user.Role</span>
                                    <span class="badge badge-outline rounded-md">@user.Status</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </article>
        </div>

        <div class="app-page-aside">
            <partial name="Shared/_AdminNav" />
        </div>
    </div>
</section>
