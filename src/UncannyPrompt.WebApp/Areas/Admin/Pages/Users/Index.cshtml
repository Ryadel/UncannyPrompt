@page
@model UncannyPrompt.WebApp.Areas.Admin.Pages.Users.IndexModel
@{
    ViewData["Title"] = Localizer["PageTitle"];
}

<section class="app-page">
    <partial name="_AppPageHeader" model="@(new AppPageHeaderModel(
        Title: Localizer["PageTitle"].Value,
        KickerParts: new[] { SharedLocalizer["Admin"].Value }))" />

    <div class="app-page-grid">
        <div class="app-page-main lg:col-span-2">
            <div class="app-list">
                @foreach (var user in Model.Users)
                {
                    <article class="app-list-item">
                        <div class="app-list-item-header">
                            <div>
                                <h2 class="app-list-item-title">@user.DisplayName</h2>
                                <p class="app-list-item-description">@user.Email</p>
                            </div>
                            <a class="btn btn-outline btn-sm rounded-lg" asp-area="Admin" asp-page="/Users/Edit" asp-route-id="@user.Id">@SharedLocalizer["Edit"]</a>
                        </div>
                        <div class="mt-3 flex flex-wrap gap-2">
                            <span class="badge rounded-md">@user.Role</span>
                            <span class="badge badge-outline rounded-md">@user.Status</span>
                            @if (!string.IsNullOrWhiteSpace(user.LastLoginProvider))
                            {
                                <span class="badge badge-outline rounded-md">@user.LastLoginProvider</span>
                            }
                        </div>
                    </article>
                }
            </div>
        </div>

        <div class="app-page-aside">
            <partial name="Shared/_AdminNav" />
        </div>
    </div>
</section>
