@page "{id:guid}"
@model UncannyPrompt.WebApp.Areas.Admin.Pages.Users.EditModel
@{
    ViewData["Title"] = Localizer["PageTitle"];
}

<section class="app-page">
    <partial name="_AppPageHeader" model="@(new AppPageHeaderModel(
        Title: Localizer["PageTitle"].Value,
        KickerParts: new[] { SharedLocalizer["Admin"].Value, SharedLocalizer["User"].Value }))" />

    <div class="app-page-grid">
        <div class="app-page-main lg:col-span-2">
            @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
            {
                <div class="app-alert app-alert-info mb-4">@Model.SuccessMessage</div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="app-alert app-alert-error mb-4">@Model.ErrorMessage</div>
            }

            <form method="post" class="app-card">
                <div class="app-card-body space-y-4">
                    <input type="hidden" asp-for="Id" />

                    @if (Model.UserDetails is not null)
                    {
                        <div>
                            <h2 class="text-xl font-bold text-zinc-950">@Model.UserDetails.DisplayName</h2>
                            <p class="text-sm text-zinc-500">@Model.UserDetails.Email</p>
                        </div>
                    }

                    <div class="grid gap-4 md:grid-cols-2">
                        <div class="app-field">
                            <label asp-for="Role" class="app-field-label">@Localizer["RoleLabel"]</label>
                            <select asp-for="Role" asp-items="Model.RoleOptions" class="app-select"></select>
                        </div>

                        <div class="app-field">
                            <label asp-for="Status" class="app-field-label">@Localizer["StatusLabel"]</label>
                            <select asp-for="Status" asp-items="Model.StatusOptions" class="app-select"></select>
                        </div>
                    </div>
                </div>

                <div class="app-card-footer">
                    <a class="btn btn-ghost btn-sm rounded-lg" asp-area="Admin" asp-page="/Users/Index">@SharedLocalizer["Cancel"]</a>
                    <button class="btn btn-primary btn-sm rounded-lg" type="submit">@SharedLocalizer["Save"]</button>
                </div>
            </form>
        </div>

        <div class="app-page-aside">
            <partial name="Shared/_AdminNav" />
        </div>
    </div>
</section>
