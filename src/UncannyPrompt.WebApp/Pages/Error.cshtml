@page
@model ErrorModel
@{
    ViewData["Title"] = Localizer["PageTitle"];
}

<h1 class="text-danger">@Localizer["ErrorHeading"]</h1>
<h2 class="text-danger">@Localizer["ErrorMessage"]</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>@Localizer["RequestIdLabel"]</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>@Localizer["DevelopmentModeHeading"]</h3>
<p>
    @Localizer["DevelopmentModeLead"]
</p>
<p>
    <strong>@Localizer["DevelopmentModeWarning"]</strong>
    @Localizer["DevelopmentModeInstructions"]
</p>
