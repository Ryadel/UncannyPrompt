@page "{id?}"
@model UncannyPrompt.WebApp.Pages.Tags.EditModel
@using UncannyPrompt.Domain
@{
    ViewData["Title"] = Localizer["NewTag"];
}

<section class="app-page">
    <partial name="_AppPageHeader" model="@(new AppPageHeaderModel(Localizer["NewTag"].Value, new[] { SharedLocalizer["Tags"].Value }))" />

    <div class="max-w-3xl">
        <article class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm">
            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="mb-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">@Model.ErrorMessage</div>
            }

            <form method="post" class="space-y-4">
                <label class="form-control">
                    <span class="label-text">@Localizer["NameLabel"]</span>
                    <input asp-for="Name" class="input input-bordered rounded-lg" placeholder="@Localizer["TagNamePlaceholder"]" />
                </label>

                <label class="form-control">
                    <span class="label-text">@Localizer["ScopeLabel"]</span>
                    <select asp-for="Scope" class="select select-bordered rounded-lg">
                        <option value="@TagScope.Personal">@SharedLocalizer["ScopePersonal"]</option>
                        <option value="@TagScope.Tenant">@SharedLocalizer["ScopeTenant"]</option>
                        <option value="@TagScope.Workspace">@SharedLocalizer["ScopeWorkspace"]</option>
                    </select>
                </label>

                <input type="hidden" asp-for="TenantId" />

                <label class="form-control">
                    <span class="label-text">@SharedLocalizer["Workspace"]</span>
                    <select asp-for="WorkspaceId" asp-items="Model.WorkspaceOptions" class="select select-bordered rounded-lg"></select>
                </label>

                <div class="flex flex-wrap gap-2">
                    <button class="btn btn-primary rounded-lg" type="submit">@Localizer["CreateTag"]</button>
                    <a class="btn btn-ghost rounded-lg" asp-page="/Tags">@SharedLocalizer["Cancel"]</a>
                </div>
            </form>
        </article>
    </div>
</section>
