@page
@model UncannyPrompt.WebApp.Pages.Help.IndexModel
@{
    ViewData["Title"] = Localizer["PageTitle"];
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

@if (!isAuthenticated)
{
    <partial name="_PublicTopNav" />
}

<section class="@(isAuthenticated ? "app-page" : "bg-white text-zinc-950")">
    <div class="@(isAuthenticated ? string.Empty : "mx-auto max-w-6xl px-4 py-12")">
        @if (isAuthenticated)
        {
            <partial name="_AppPageHeader" model="@(new AppPageHeaderModel(Localizer["PageTitle"].Value, new[] { SharedLocalizer["NavHelp"].Value }))" />
        }

        <div class="app-page-body">
            <div class="app-page-main">
                <article class="rounded-lg border border-zinc-200 bg-white p-6">
                    <h1 class="text-3xl font-bold text-zinc-950">@Localizer["HeroTitle"]</h1>
                    <div class="mt-4 space-y-3 text-sm leading-6 text-zinc-600">
                        <p>@Localizer["HeroIntro"]</p>
                        <p>@Localizer["HeroWorkflow"]</p>
                        <p>@Localizer["HeroUseCases"]</p>
                    </div>
                </article>

                <div class="mt-6 grid gap-4 lg:grid-cols-3">
                    <a asp-page="/Help/Overview" class="group rounded-lg border border-zinc-200 bg-white p-5 transition hover:border-uncanny-300 hover:shadow-sm">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <h2 class="text-lg font-bold text-zinc-950">@Localizer["OverviewTitle"]</h2>
                                <p class="mt-2 text-sm leading-6 text-zinc-600">@Localizer["OverviewDescription"]</p>
                            </div>
                            <svg class="mt-1 h-4 w-4 shrink-0 text-zinc-300 transition group-hover:translate-x-0.5 group-hover:text-uncanny-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                        </div>
                    </a>

                    <a asp-page="/Help/Access" class="group rounded-lg border border-zinc-200 bg-white p-5 transition hover:border-uncanny-300 hover:shadow-sm">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <h2 class="text-lg font-bold text-zinc-950">@Localizer["AccessTitle"]</h2>
                                <p class="mt-2 text-sm leading-6 text-zinc-600">@Localizer["AccessDescription"]</p>
                            </div>
                            <svg class="mt-1 h-4 w-4 shrink-0 text-zinc-300 transition group-hover:translate-x-0.5 group-hover:text-uncanny-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                        </div>
                    </a>

                    <a asp-page="/Help/Api" class="group rounded-lg border border-zinc-200 bg-white p-5 transition hover:border-uncanny-300 hover:shadow-sm">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <h2 class="text-lg font-bold text-zinc-950">@Localizer["ApiTitle"]</h2>
                                <p class="mt-2 text-sm leading-6 text-zinc-600">@Localizer["ApiDescription"]</p>
                            </div>
                            <svg class="mt-1 h-4 w-4 shrink-0 text-zinc-300 transition group-hover:translate-x-0.5 group-hover:text-uncanny-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
