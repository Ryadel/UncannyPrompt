@page
@model UncannyPrompt.WebApp.Pages.Help.OverviewModel
@{
    ViewData["Title"] = Localizer["PageTitle"];
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

@if (!isAuthenticated)
{
    <partial name="_PublicTopNav" />
}

<section class="@(isAuthenticated ? "app-page" : "bg-white text-zinc-950")">
    <div class="@(isAuthenticated ? string.Empty : "mx-auto max-w-6xl px-4 py-12")">
        @if (isAuthenticated)
        {
            <partial name="_AppPageHeader" model="@(new AppPageHeaderModel(Localizer["PageTitle"].Value, new[] { SharedLocalizer["NavHelp"].Value }))" />
        }

        <div class="app-page-body">
            <div class="app-page-main space-y-6">
                <article class="rounded-lg border border-zinc-200 bg-white p-6">
                    <h1 class="text-3xl font-bold text-zinc-950">@Localizer["PageHeading"]</h1>
                    <p class="mt-3 text-sm leading-6 text-zinc-600">@Localizer["Intro"]</p>
                </article>

                <article class="rounded-lg border border-zinc-200 bg-white p-6">
                    <h2 class="text-xl font-bold text-zinc-950">@Localizer["BuildingBlocksTitle"]</h2>
                    <div class="mt-4 overflow-x-auto">
                        <table class="min-w-full divide-y divide-zinc-200 text-sm">
                            <thead class="text-left text-xs font-semibold uppercase tracking-wider text-zinc-500">
                                <tr>
                                    <th class="px-3 py-2">@Localizer["NameHeader"]</th>
                                    <th class="px-3 py-2">@Localizer["MeaningHeader"]</th>
                                    <th class="px-3 py-2">@Localizer["UsageHeader"]</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-zinc-100 text-zinc-600">
                                <tr>
                                    <td class="px-3 py-3 font-semibold text-zinc-950">@SharedLocalizer["Tenant"]</td>
                                    <td class="px-3 py-3">@Localizer["TenantMeaning"]</td>
                                    <td class="px-3 py-3">@Localizer["TenantUsage"]</td>
                                </tr>
                                <tr>
                                    <td class="px-3 py-3 font-semibold text-zinc-950">@SharedLocalizer["Workspace"]</td>
                                    <td class="px-3 py-3">@Localizer["WorkspaceMeaning"]</td>
                                    <td class="px-3 py-3">@Localizer["WorkspaceUsage"]</td>
                                </tr>
                                <tr>
                                    <td class="px-3 py-3 font-semibold text-zinc-950">@SharedLocalizer["Project"]</td>
                                    <td class="px-3 py-3">@Localizer["ProjectMeaning"]</td>
                                    <td class="px-3 py-3">@Localizer["ProjectUsage"]</td>
                                </tr>
                                <tr>
                                    <td class="px-3 py-3 font-semibold text-zinc-950">@SharedLocalizer["Prompt"]</td>
                                    <td class="px-3 py-3">@Localizer["PromptMeaning"]</td>
                                    <td class="px-3 py-3">@Localizer["PromptUsage"]</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </article>

                <div class="grid gap-4 lg:grid-cols-2">
                    <article class="rounded-lg border border-zinc-200 bg-white p-6">
                        <h2 class="text-xl font-bold text-zinc-950">@Localizer["WorkflowTitle"]</h2>
                        <ol class="mt-4 list-decimal space-y-2 pl-5 text-sm leading-6 text-zinc-600">
                            <li>@Localizer["WorkflowStepTenant"]</li>
                            <li>@Localizer["WorkflowStepWorkspace"]</li>
                            <li>@Localizer["WorkflowStepProject"]</li>
                            <li>@Localizer["WorkflowStepPrompt"]</li>
                            <li>@Localizer["WorkflowStepShare"]</li>
                        </ol>
                    </article>

                    <article class="rounded-lg border border-zinc-200 bg-white p-6">
                        <h2 class="text-xl font-bold text-zinc-950">@Localizer["TraceabilityTitle"]</h2>
                        <div class="mt-4 space-y-3 text-sm leading-6 text-zinc-600">
                            <p>@Localizer["TraceabilityVersions"]</p>
                            <p>@Localizer["TraceabilityVariables"]</p>
                            <p>@Localizer["TraceabilityAudit"]</p>
                        </div>
                    </article>
                </div>
            </div>
        </div>
    </div>
</section>
