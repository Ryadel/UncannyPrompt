@page
@model UncannyPrompt.WebApp.Pages.Help.ApiModel
@{
    ViewData["Title"] = Localizer["PageTitle"];
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

@if (!isAuthenticated)
{
    <partial name="_PublicTopNav" />
}

<section class="@(isAuthenticated ? "app-page" : "bg-white text-zinc-950")">
    <div class="@(isAuthenticated ? string.Empty : "mx-auto max-w-6xl px-4 py-12")">
        @if (isAuthenticated)
        {
            <partial name="_AppPageHeader" model="@(new AppPageHeaderModel(Localizer["PageTitle"].Value, new[] { SharedLocalizer["NavHelp"].Value }))" />
        }

        <div class="app-page-body">
            <div class="app-page-main space-y-6">
                <article class="rounded-lg border border-zinc-200 bg-white p-6">
                    <h1 class="text-3xl font-bold text-zinc-950">@Localizer["PageHeading"]</h1>
                    <p class="mt-3 text-sm leading-6 text-zinc-600">@Localizer["Intro"]</p>
                </article>

                <div class="grid gap-4 lg:grid-cols-2">
                    <article class="rounded-lg border border-zinc-200 bg-white p-6">
                        <h2 class="text-xl font-bold text-zinc-950">@Localizer["AuthTitle"]</h2>
                        <ul class="mt-4 list-disc space-y-2 pl-5 text-sm leading-6 text-zinc-600">
                            <li>@Localizer["AuthCookie"]</li>
                            <li>@Localizer["AuthApiKey"] <code class="rounded bg-zinc-100 px-1.5 py-0.5 text-xs text-zinc-800">X-API-Key</code>.</li>
                            <li>@Localizer["AuthBearer"] <code class="rounded bg-zinc-100 px-1.5 py-0.5 text-xs text-zinc-800">Authorization: Bearer &lt;key&gt;</code>.</li>
                            <li>@Localizer["AuthSwagger"]</li>
                        </ul>
                    </article>

                    <article class="rounded-lg border border-zinc-200 bg-white p-6">
                        <h2 class="text-xl font-bold text-zinc-950">@Localizer["PermissionsTitle"]</h2>
                        <p class="mt-4 text-sm leading-6 text-zinc-600">@Localizer["PermissionsDescription"]</p>
                    </article>
                </div>

                <article class="rounded-lg border border-zinc-200 bg-white p-6">
                    <h2 class="text-xl font-bold text-zinc-950">@Localizer["CapabilitiesTitle"]</h2>
                    <div class="mt-4 grid gap-4 md:grid-cols-3">
                        <div class="rounded-lg border border-zinc-200 p-4">
                            <h3 class="font-semibold text-zinc-950">@Localizer["CatalogTitle"]</h3>
                            <p class="mt-2 text-sm leading-6 text-zinc-600">@Localizer["CatalogDescription"]</p>
                        </div>
                        <div class="rounded-lg border border-zinc-200 p-4">
                            <h3 class="font-semibold text-zinc-950">@Localizer["AutomationTitle"]</h3>
                            <p class="mt-2 text-sm leading-6 text-zinc-600">@Localizer["AutomationDescription"]</p>
                        </div>
                        <div class="rounded-lg border border-zinc-200 p-4">
                            <h3 class="font-semibold text-zinc-950">@Localizer["GovernanceTitle"]</h3>
                            <p class="mt-2 text-sm leading-6 text-zinc-600">@Localizer["GovernanceDescription"]</p>
                        </div>
                    </div>
                </article>

                <article class="rounded-lg border border-zinc-200 bg-white p-6">
                    <h2 class="text-xl font-bold text-zinc-950">@Localizer["EndpointsTitle"]</h2>
                    <p class="mt-2 text-sm leading-6 text-zinc-600">@Localizer["EndpointsIntro"]</p>
                    <div class="mt-4 flex flex-wrap gap-2">
                        <code class="rounded-md bg-zinc-100 px-2.5 py-1 text-xs text-zinc-700">/api/prompts</code>
                        <code class="rounded-md bg-zinc-100 px-2.5 py-1 text-xs text-zinc-700">/api/projects</code>
                        <code class="rounded-md bg-zinc-100 px-2.5 py-1 text-xs text-zinc-700">/api/folders</code>
                        <code class="rounded-md bg-zinc-100 px-2.5 py-1 text-xs text-zinc-700">/api/tags</code>
                        <code class="rounded-md bg-zinc-100 px-2.5 py-1 text-xs text-zinc-700">/api/variables</code>
                        <code class="rounded-md bg-zinc-100 px-2.5 py-1 text-xs text-zinc-700">/api/shares</code>
                        <code class="rounded-md bg-zinc-100 px-2.5 py-1 text-xs text-zinc-700">/api/public-links</code>
                        <code class="rounded-md bg-zinc-100 px-2.5 py-1 text-xs text-zinc-700">/api/audit</code>
                    </div>
                </article>

                <article class="rounded-lg border border-zinc-200 bg-white p-6">
                    <h2 class="text-xl font-bold text-zinc-950">@Localizer["DetailsTitle"]</h2>
                    <p class="mt-2 text-sm leading-6 text-zinc-600">@Localizer["DetailsDescription"]</p>
                    <div class="mt-4 flex flex-wrap justify-end gap-2">
                        <a asp-page="/Developer/Api/Index" class="btn btn-primary btn-sm gap-1.5 rounded-lg">
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="7.5" cy="15.5" r="5.5"/><path d="m21 2-9.6 9.6"/><path d="m15 8 2 2"/><path d="m17 6 2 2"/></svg>
                            @Localizer["ApiKeysButton"]
                        </a>
                        <a asp-page="/Developer/Api/Docs" class="btn btn-outline btn-sm gap-1.5 rounded-lg">
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M9 13h6"/><path d="M9 17h4"/></svg>
                            @Localizer["ApiDocsButton"]
                        </a>
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>
