@page
@model UncannyPrompt.WebApp.Pages.Help.AccessModel
@{
    ViewData["Title"] = Localizer["PageTitle"];
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

@if (!isAuthenticated)
{
    <partial name="_PublicTopNav" />
}

<section class="@(isAuthenticated ? "app-page" : "bg-white text-zinc-950")">
    <div class="@(isAuthenticated ? string.Empty : "mx-auto max-w-6xl px-4 py-12")">
        @if (isAuthenticated)
        {
            <partial name="_AppPageHeader" model="@(new AppPageHeaderModel(Localizer["PageTitle"].Value, new[] { SharedLocalizer["NavHelp"].Value }))" />
        }

        <div class="app-page-body">
            <div class="app-page-main space-y-6">
                <article class="rounded-lg border border-zinc-200 bg-white p-6">
                    <h1 class="text-3xl font-bold text-zinc-950">@Localizer["PageHeading"]</h1>
                    <p class="mt-3 text-sm leading-6 text-zinc-600">@Localizer["Intro"]</p>
                </article>

                <div class="grid gap-4 lg:grid-cols-2">
                    <article class="rounded-lg border border-zinc-200 bg-white p-6">
                        <h2 class="text-xl font-bold text-zinc-950">@Localizer["SigningInTitle"]</h2>
                        <ul class="mt-4 list-disc space-y-2 pl-5 text-sm leading-6 text-zinc-600">
                            <li>@Localizer["SigningInProviders"]</li>
                            <li>@Localizer["SigningInProvisioning"]</li>
                            <li>@Localizer["SigningInPersonalTenant"]</li>
                            <li>@Localizer["SigningInSignOut"]</li>
                        </ul>
                    </article>

                    <article class="rounded-lg border border-zinc-200 bg-white p-6">
                        <h2 class="text-xl font-bold text-zinc-950">@Localizer["ScopeTitle"]</h2>
                        <div class="mt-4 space-y-3 text-sm leading-6 text-zinc-600">
                            <p>@Localizer["ScopeCurrentTenant"]</p>
                            <p>@Localizer["ScopeWorkspaceProject"]</p>
                            <p>@Localizer["ScopePublicLinks"]</p>
                        </div>
                    </article>
                </div>

                <article class="rounded-lg border border-zinc-200 bg-white p-6">
                    <h2 class="text-xl font-bold text-zinc-950">@Localizer["RolesTitle"]</h2>
                    <p class="mt-2 text-sm leading-6 text-zinc-600">@Localizer["RolesIntro"]</p>
                    <div class="mt-4 overflow-x-auto">
                        <table class="min-w-full divide-y divide-zinc-200 text-sm">
                            <thead class="text-left text-xs font-semibold uppercase tracking-wider text-zinc-500">
                                <tr>
                                    <th class="px-3 py-2">@Localizer["RoleHeader"]</th>
                                    <th class="px-3 py-2">@Localizer["RoleMeaningHeader"]</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-zinc-100 text-zinc-600">
                                <tr><td class="px-3 py-3 font-semibold text-zinc-950">@Localizer["TenantOwnerRole"]</td><td class="px-3 py-3">@Localizer["TenantOwnerDescription"]</td></tr>
                                <tr><td class="px-3 py-3 font-semibold text-zinc-950">@Localizer["TenantManagerRole"]</td><td class="px-3 py-3">@Localizer["TenantManagerDescription"]</td></tr>
                                <tr><td class="px-3 py-3 font-semibold text-zinc-950">@Localizer["WorkspaceManagerRole"]</td><td class="px-3 py-3">@Localizer["WorkspaceManagerDescription"]</td></tr>
                                <tr><td class="px-3 py-3 font-semibold text-zinc-950">@Localizer["ProjectContributorRole"]</td><td class="px-3 py-3">@Localizer["ProjectContributorDescription"]</td></tr>
                                <tr><td class="px-3 py-3 font-semibold text-zinc-950">@Localizer["ReviewerRole"]</td><td class="px-3 py-3">@Localizer["ReviewerDescription"]</td></tr>
                                <tr><td class="px-3 py-3 font-semibold text-zinc-950">@Localizer["ViewerRole"]</td><td class="px-3 py-3">@Localizer["ViewerDescription"]</td></tr>
                            </tbody>
                        </table>
                    </div>
                </article>
            </div>
        </div>
    </div>
</section>
