@page
@model UncannyPrompt.WebApp.Pages.Developer.Api.EditModel
@{
    var titleString = Localizer["PageTitle"].Value;
    ViewData["Title"] = titleString;
}

<section class="app-page">
    <partial name="_AppPageHeader" model="@(new AppPageHeaderModel(
        Title: titleString,
        KickerParts: new[] { SharedLocalizer["NavGroupDevelopers"].Value, SharedLocalizer["NavApiKeys"].Value }))" />

    <div class="app-page-body">
        <div class="app-page-main">
            <div class="mx-auto max-w-3xl space-y-6">
                @if (!string.IsNullOrWhiteSpace(Model.SuccessMessageKey))
                {
                    <div class="app-alert app-alert-success">@Localizer[Model.SuccessMessageKey]</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessageKey))
                {
                    <div class="app-alert app-alert-error">@Localizer[Model.ErrorMessageKey]</div>
                }

                @if (Model.CreatedApiKey is not null)
                {
                    <article class="rounded-lg border border-emerald-200 bg-emerald-50 p-5">
                        <h2 class="text-lg font-bold text-emerald-900">@Localizer["CopyKeyTitle"]</h2>
                        <p class="mt-2 text-sm leading-6 text-emerald-800">@Localizer["CopyKeyDescription"]</p>
                        <div class="mt-4 flex flex-col gap-2 sm:flex-row">
                            <input id="created-api-key" type="text" readonly class="app-input font-mono text-sm" value="@Model.CreatedApiKey.PlainTextKey" />
                            <button type="button" class="btn btn-primary shrink-0 rounded-lg" onclick="copyCreatedApiKey()">@Localizer["CopyButton"]</button>
                        </div>
                    </article>
                }

                <form method="post" class="app-card">
                    <div class="app-card-body">
                        <div class="app-field">
                            <label asp-for="Name" class="app-field-label">@Localizer["NameLabel"]</label>
                            <input asp-for="Name" maxlength="120" class="app-input" placeholder="@Localizer["NamePlaceholder"]" />
                            <p class="app-field-hint">@Localizer["NameHint"]</p>
                        </div>

                        <div class="app-field app-field-divider">
                            <label asp-for="ExpiresAtDate" class="app-field-label">
                                @Localizer["ExpiresLabel"]
                                <span class="app-field-label-optional">- @Localizer["OptionalLabel"]</span>
                            </label>
                            <input asp-for="ExpiresAtDate" type="date" class="app-input" />
                            <p class="app-field-hint">@Localizer["ExpiresHint"]</p>
                        </div>
                    </div>

                    <div class="app-card-footer">
                        <a class="btn btn-ghost btn-sm rounded-lg" asp-page="/Developer/Api/Index">@SharedLocalizer["Cancel"]</a>
                        <button class="btn btn-primary btn-sm rounded-lg" type="submit">@Localizer["GenerateButton"]</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<script>
    function copyCreatedApiKey() {
        const input = document.getElementById('created-api-key');
        if (!input) return;
        input.select();
        input.setSelectionRange(0, input.value.length);
        navigator.clipboard.writeText(input.value);
    }
</script>
