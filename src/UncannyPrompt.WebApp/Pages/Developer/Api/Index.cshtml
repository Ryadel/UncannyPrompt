@page
@model UncannyPrompt.WebApp.Pages.Developer.Api.IndexModel
@{
    var titleString = Localizer["PageTitle"].Value;
    ViewData["Title"] = titleString;
}

<section class="app-page">
    <partial name="_AppPageHeader" model="@(new AppPageHeaderModel(
        Title: titleString,
        KickerParts: new[] { SharedLocalizer["NavGroupDevelopers"].Value },
        Action: new AppPageHeaderAction(Localizer["CreateKeyButton"].Value, "/Developer/Api/Edit")))" />

    <div class="app-page-body">
        <div class="app-page-main space-y-6">
            <article class="rounded-lg border border-zinc-200 bg-white p-6">
                <div class="flex flex-wrap items-start justify-between gap-4">
                    <div>
                        <h2 class="text-xl font-bold text-zinc-950">@Localizer["IntroTitle"]</h2>
                        <p class="mt-2 max-w-3xl text-sm leading-6 text-zinc-600">@Localizer["IntroBody"]</p>
                    </div>
                    <a class="btn btn-ghost btn-sm gap-1.5 rounded-lg" asp-page="/Developer/Api/Docs">
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M9 13h6"/><path d="M9 17h4"/></svg>
                        @Localizer["DocsButton"]
                    </a>
                </div>
                <div class="mt-4 rounded-lg border border-zinc-200 bg-zinc-50 p-4 text-sm leading-6 text-zinc-600">
                    <ul class="list-disc space-y-1 pl-5">
                        <li>@Localizer["UseHeaderPrefix"] <code class="rounded bg-white px-1.5 py-0.5 text-xs text-zinc-800">X-API-Key</code>.</li>
                        <li>@Localizer["UseBearerPrefix"] <code class="rounded bg-white px-1.5 py-0.5 text-xs text-zinc-800">Authorization: Bearer &lt;key&gt;</code>.</li>
                        <li>@Localizer["ShownOnce"]</li>
                    </ul>
                </div>
            </article>

            @if (!string.IsNullOrWhiteSpace(Model.SuccessMessageKey))
            {
                <div class="app-alert app-alert-success">@Localizer[Model.SuccessMessageKey]</div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessageKey))
            {
                <div class="app-alert app-alert-error">@Localizer[Model.ErrorMessageKey]</div>
            }

            <article class="rounded-lg border border-zinc-200 bg-white p-6">
                <div class="flex flex-wrap items-center justify-between gap-3">
                    <h2 class="text-xl font-bold text-zinc-950">@Localizer["KeysTitle"]</h2>
                    <a class="btn btn-primary btn-sm gap-1.5 rounded-lg" asp-page="/Developer/Api/Edit">
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15.5 7.5 19 4l1 1-3.5 3.5"/><path d="m14 9 1 1"/><path d="M2 22l6-6"/><circle cx="11" cy="13" r="5"/><path d="M18 13h4"/><path d="M20 11v4"/></svg>
                        @Localizer["CreateKeyButton"]
                    </a>
                </div>

                @if (Model.ApiKeys.Count == 0)
                {
                    <div class="mt-4 rounded-lg border border-dashed border-zinc-300 bg-zinc-50 p-5 text-sm leading-6 text-zinc-600">
                        @Localizer["NoKeys"]
                    </div>
                }
                else
                {
                    <div class="mt-4 overflow-x-auto">
                        <table class="min-w-full divide-y divide-zinc-200 text-sm">
                            <thead class="text-left text-xs font-semibold uppercase tracking-wider text-zinc-500">
                                <tr>
                                    <th class="px-3 py-2">@Localizer["NameHeader"]</th>
                                    <th class="px-3 py-2">@Localizer["PrefixHeader"]</th>
                                    <th class="px-3 py-2">@Localizer["CreatedHeader"]</th>
                                    <th class="px-3 py-2">@Localizer["LastUsedHeader"]</th>
                                    <th class="px-3 py-2">@Localizer["ExpiresHeader"]</th>
                                    <th class="px-3 py-2 text-right">@Localizer["ActionsHeader"]</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-zinc-100 text-zinc-600">
                                @foreach (var key in Model.ApiKeys)
                                {
                                    <tr>
                                        <td class="px-3 py-3 font-semibold text-zinc-950">@key.Name</td>
                                        <td class="px-3 py-3 font-mono text-xs">@key.Prefix...</td>
                                        <td class="px-3 py-3">@key.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="px-3 py-3">@(key.LastUsedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                        <td class="px-3 py-3">@(key.ExpiresAt?.ToLocalTime().ToString("dd/MM/yyyy") ?? "-")</td>
                                        <td class="px-3 py-3 text-right">
                                            <form method="post" asp-page-handler="Revoke" class="inline">
                                                <input type="hidden" name="ApiKeyId" value="@key.Id" />
                                                <button class="btn btn-ghost btn-sm gap-1.5 rounded-lg text-rose-700" type="submit" onclick="return confirm('@Localizer["RevokeConfirmation"]')">
                                                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 18h12"/><path d="m9 11 3 3"/><path d="m12 11-3 3"/><circle cx="16" cy="8" r="6"/><path d="m21 3-10 10"/></svg>
                                                    @Localizer["RevokeButton"]
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </article>
        </div>
    </div>
</section>
