@page
@model UncannyPrompt.WebApp.Pages.Developer.Api.DocsModel
@{
    var titleString = Localizer["PageTitle"].Value;
    ViewData["Title"] = titleString;
}

<section class="app-page">
    <partial name="_AppPageHeader" model="@(new AppPageHeaderModel(
        Title: titleString,
        KickerParts: new[] { SharedLocalizer["NavGroupDevelopers"].Value }))" />

    <div class="app-page-body">
        <div class="app-page-main space-y-6">
            <article class="rounded-lg border border-zinc-200 bg-white p-6">
                <div class="flex flex-wrap items-start justify-between gap-4">
                    <div>
                        <h2 class="text-xl font-bold text-zinc-950">@Localizer["IntroTitle"]</h2>
                        <p class="mt-2 text-sm leading-6 text-zinc-600">@Localizer["BaseUrl"] <code class="rounded bg-zinc-100 px-1.5 py-0.5 text-xs text-zinc-800">@Model.BaseUrl</code></p>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <a class="btn btn-ghost btn-sm rounded-lg" asp-page="/Developer/Api/Index">@Localizer["BackToKeys"]</a>
                        <a class="btn btn-primary btn-sm rounded-lg" href="/swagger" target="_blank" rel="noopener">@Localizer["OpenSwagger"]</a>
                    </div>
                </div>
                <div class="mt-4 rounded-lg border border-zinc-200 bg-zinc-50 p-4 text-sm leading-6 text-zinc-600">
                    <ul class="list-disc space-y-1 pl-5">
                        <li>@Localizer["UseHeaderPrefix"] <code class="rounded bg-white px-1.5 py-0.5 text-xs text-zinc-800">X-API-Key: &lt;your-api-key&gt;</code>.</li>
                        <li>@Localizer["UseBearerPrefix"] <code class="rounded bg-white px-1.5 py-0.5 text-xs text-zinc-800">Authorization: Bearer &lt;your-api-key&gt;</code>.</li>
                        <li>@Localizer["EndpointsUnderApi"] <code class="rounded bg-white px-1.5 py-0.5 text-xs text-zinc-800">/api</code>.</li>
                    </ul>
                </div>
            </article>

            <article class="rounded-lg border border-zinc-200 bg-white p-6">
                <h2 class="text-xl font-bold text-zinc-950">@Localizer["QuickstartTitle"]</h2>
                <pre class="mt-4 overflow-x-auto rounded-lg border border-zinc-200 bg-zinc-950 p-4 text-xs leading-6 text-zinc-100"><code>export UNCANNY_BASE_URL="@Model.BaseUrl"
export UNCANNY_API_KEY="upk_..."

curl -s "$UNCANNY_BASE_URL/api/workspaces" \
  -H "X-API-Key: $UNCANNY_API_KEY"</code></pre>
            </article>

            <article class="rounded-lg border border-zinc-200 bg-white p-6">
                <h2 class="text-xl font-bold text-zinc-950">@Localizer["ExamplesTitle"]</h2>
                <div class="mt-4 space-y-5">
                    <div>
                        <h3 class="font-semibold text-zinc-950">@Localizer["GetWorkspaceTitle"]</h3>
                        <pre class="mt-2 overflow-x-auto rounded-lg border border-zinc-200 bg-zinc-50 p-4 text-xs leading-6 text-zinc-700"><code>curl -s "$UNCANNY_BASE_URL/api/workspaces/{workspaceId}" \
  -H "X-API-Key: $UNCANNY_API_KEY"</code></pre>
                    </div>

                    <div>
                        <h3 class="font-semibold text-zinc-950">@Localizer["ListProjectsTitle"]</h3>
                        <pre class="mt-2 overflow-x-auto rounded-lg border border-zinc-200 bg-zinc-50 p-4 text-xs leading-6 text-zinc-700"><code>curl -s "$UNCANNY_BASE_URL/api/projects?workspaceId={workspaceId}" \
  -H "X-API-Key: $UNCANNY_API_KEY"</code></pre>
                    </div>

                    <div>
                        <h3 class="font-semibold text-zinc-950">@Localizer["GetProjectTitle"]</h3>
                        <pre class="mt-2 overflow-x-auto rounded-lg border border-zinc-200 bg-zinc-50 p-4 text-xs leading-6 text-zinc-700"><code>curl -s "$UNCANNY_BASE_URL/api/projects/{projectId}" \
  -H "X-API-Key: $UNCANNY_API_KEY"</code></pre>
                    </div>

                    <div>
                        <h3 class="font-semibold text-zinc-950">@Localizer["ListPromptsTitle"]</h3>
                        <pre class="mt-2 overflow-x-auto rounded-lg border border-zinc-200 bg-zinc-50 p-4 text-xs leading-6 text-zinc-700"><code>curl -s "$UNCANNY_BASE_URL/api/prompts?page=1&amp;pageSize=20" \
  -H "X-API-Key: $UNCANNY_API_KEY"</code></pre>
                    </div>

                    <div>
                        <h3 class="font-semibold text-zinc-950">@Localizer["GetPromptTitle"]</h3>
                        <pre class="mt-2 overflow-x-auto rounded-lg border border-zinc-200 bg-zinc-50 p-4 text-xs leading-6 text-zinc-700"><code>curl -s "$UNCANNY_BASE_URL/api/prompts/{promptId}" \
  -H "X-API-Key: $UNCANNY_API_KEY"</code></pre>
                    </div>

                    <div>
                        <h3 class="font-semibold text-zinc-950">@Localizer["PromptsByTagTitle"]</h3>
                        <pre class="mt-2 overflow-x-auto rounded-lg border border-zinc-200 bg-zinc-50 p-4 text-xs leading-6 text-zinc-700"><code>curl -s "$UNCANNY_BASE_URL/api/prompts/by-tag/support?page=1&amp;pageSize=20" \
  -H "X-API-Key: $UNCANNY_API_KEY"</code></pre>
                    </div>

                    <div>
                        <h3 class="font-semibold text-zinc-950">@Localizer["PromptsByFolderTitle"]</h3>
                        <pre class="mt-2 overflow-x-auto rounded-lg border border-zinc-200 bg-zinc-50 p-4 text-xs leading-6 text-zinc-700"><code>curl -s "$UNCANNY_BASE_URL/api/prompts/by-folder/{folderId}?page=1&amp;pageSize=20" \
  -H "X-API-Key: $UNCANNY_API_KEY"</code></pre>
                    </div>
                </div>
            </article>
        </div>
    </div>
</section>
