@page
@model UncannyPrompt.WebApp.Pages.Account.LoginModel
@{
    ViewData["Title"] = Model.IsSignupIntent ? Localizer["CreateAccountTitle"] : Localizer["PageTitle"];
}

<section class="flex min-h-screen items-center justify-center bg-zinc-50 px-4 py-10">
    <div class="w-full max-w-md">
        <div class="mb-6 text-center">
            <a href="/" class="inline-flex items-center justify-center gap-3" aria-label="@SharedLocalizer["AppName"]">
                <img src="~/img/logo.svg" alt="" class="h-12 w-auto" />
                <span class="brand-wordmark text-2xl"><span class="brand-wordmark-primary">Uncanny</span><span class="brand-wordmark-accent">Prompt</span></span>
            </a>
        </div>

        <div class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm sm:p-8">
            <h1 class="text-2xl font-bold text-zinc-950">@(Model.IsSignupIntent ? Localizer["CreateAccountTitle"] : Localizer["SignInTitle"])</h1>
            <p class="mt-1 text-sm text-zinc-600">@(Model.IsSignupIntent ? Localizer["CreateAccountSubtitle"] : Localizer["SignInSubtitle"])</p>

            @if (Model.HasError)
            {
                <div role="alert" class="mt-5 rounded-lg border border-rose-200 bg-rose-50 p-3 text-sm text-rose-800">
                    @Localizer["SignInError"]
                </div>
            }

            @if (Model.HasExternalProviders)
            {
                <div class="mt-6 grid gap-2.5">
                    @if (Model.IsGoogleEnabled)
                    {
                        <a class="group flex items-center gap-3 rounded-lg border border-zinc-200 bg-white px-4 py-2.5 text-sm font-medium text-zinc-800 transition hover:border-uncanny-600 hover:bg-uncanny-50/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-uncanny-600"
                           href="/account/signin/google?returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)" rel="nofollow">
                            <svg class="h-5 w-5 shrink-0" viewBox="0 0 48 48" aria-hidden="true">
                                <path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z" />
                                <path fill="#FF3D00" d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z" />
                                <path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238C29.211 35.091 26.715 36 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z" />
                                <path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303c-.792 2.237-2.231 4.166-4.087 5.571l6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z" />
                            </svg>
                            <span>@Localizer["LoginWithGoogle"]</span>
                        </a>
                    }
                    @if (Model.IsEntraEnabled)
                    {
                        <a class="group flex items-center gap-3 rounded-lg border border-zinc-200 bg-white px-4 py-2.5 text-sm font-medium text-zinc-800 transition hover:border-uncanny-600 hover:bg-uncanny-50/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-uncanny-600"
                           href="/account/signin/entra?returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)" rel="nofollow">
                            <svg class="h-5 w-5 shrink-0" viewBox="0 0 23 23" aria-hidden="true">
                                <rect x="1" y="1" width="10" height="10" fill="#F25022" />
                                <rect x="12" y="1" width="10" height="10" fill="#7FBA00" />
                                <rect x="1" y="12" width="10" height="10" fill="#00A4EF" />
                                <rect x="12" y="12" width="10" height="10" fill="#FFB900" />
                            </svg>
                            <span>@Localizer["LoginWithMicrosoftEntraId"]</span>
                        </a>
                    }
                    @if (Model.IsGitHubEnabled)
                    {
                        <a class="group flex items-center gap-3 rounded-lg border border-zinc-200 bg-white px-4 py-2.5 text-sm font-medium text-zinc-800 transition hover:border-uncanny-600 hover:bg-uncanny-50/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-uncanny-600"
                           href="/account/signin/github?returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)" rel="nofollow">
                            <svg class="h-5 w-5 shrink-0 text-zinc-950" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" clip-rule="evenodd" d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                            </svg>
                            <span>@Localizer["LoginWithGitHub"]</span>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="mt-6 rounded-lg border border-zinc-200 bg-zinc-50 p-4 text-sm text-zinc-600">
                    @Localizer["NoExternalProviderConfigured"]
                </div>
            }
        </div>

        <p class="mt-4 flex items-center justify-center gap-2 text-center text-xs text-zinc-500">
            <a class="hover:text-uncanny-700 hover:underline" asp-page="/Index">@Localizer["HomeLink"]</a>
            <span class="text-zinc-300" aria-hidden="true">/</span>
            <a class="hover:text-uncanny-700 hover:underline" asp-page="/Privacy">@Localizer["PrivacyLink"]</a>
            @if (Model.IsDevelopment)
            {
                <span class="text-zinc-300" aria-hidden="true">/</span>
                <a class="hover:text-uncanny-700 hover:underline" asp-page="/Account/DevLogin" asp-route-returnUrl="@Model.ReturnUrl">@Localizer["DevLoginLink"]</a>
            }
        </p>
    </div>
</section>
