@model EmptyStateModel
@{
    var (iconBg, iconFg) = Model.Tone switch
    {
        EmptyStateTone.Blocker => ("bg-amber-50", "text-amber-700"),
        _ => ("bg-zinc-100", "text-zinc-600"),
    };
}

<div class="mx-auto mt-6 max-w-2xl rounded-xl border border-zinc-200 bg-white shadow-sm sm:mt-8">
    <div class="flex items-start gap-5 p-6">
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg @iconBg @iconFg">
            @switch (Model.Icon)
            {
                case EmptyStateIcon.Workspace:
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0 4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0-5.571 3-5.571-3" />
                    </svg>
                    break;
                case EmptyStateIcon.Project:
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0 1 12 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                    break;
                case EmptyStateIcon.Lock:
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                    </svg>
                    break;
            }
        </div>
        <div class="min-w-0 flex-1">
            <h2 class="text-lg font-semibold text-zinc-950">@Model.Title</h2>
            <p class="mt-1.5 text-sm leading-6 text-zinc-600">@Model.Description</p>
            <div class="mt-4">
                <a class="btn btn-primary btn-sm rounded-lg"
                   asp-page="@Model.PrimaryActionPage"
                   asp-fragment="@Model.PrimaryActionFragment">@Model.PrimaryActionLabel</a>
            </div>
        </div>
    </div>
</div>
