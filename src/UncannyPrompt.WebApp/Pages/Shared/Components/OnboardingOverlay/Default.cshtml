@{
    Layout = null;
}

<div x-data="{ visible: sessionStorage.getItem('uncanny.onboardingHidden') !== '1' }"
     x-show="visible"
     x-cloak
     class="fixed inset-0 z-50 flex items-center justify-center overflow-y-auto bg-zinc-950/70 px-4 py-8 backdrop-blur-md"
     role="dialog"
     aria-modal="true"
     aria-labelledby="onboarding-overlay-title">

    <div class="w-full max-w-xl rounded-2xl border border-zinc-200 bg-white shadow-2xl">

        <div class="flex items-start gap-4 border-b border-zinc-100 p-6">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-zinc-100 text-zinc-700">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
                </svg>
            </div>
            <div class="min-w-0 flex-1">
                <h2 id="onboarding-overlay-title" class="text-xl font-semibold text-zinc-950">@Localizer["WelcomeTitle"]</h2>
                <p class="mt-1.5 text-sm leading-6 text-zinc-600">@Localizer["WelcomeBody"]</p>
            </div>
        </div>

        <div class="space-y-5 p-6">
            <div class="flex items-start gap-4">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-zinc-900 text-xs font-semibold text-white">1</span>
                <div class="min-w-0">
                    <h3 class="text-sm font-semibold text-zinc-950">@Localizer["StepOneTitle"]</h3>
                    <p class="mt-1 text-sm leading-6 text-zinc-600">@Localizer["StepOneBody"]</p>
                </div>
            </div>
            <div class="flex items-start gap-4">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-zinc-900 text-xs font-semibold text-white">2</span>
                <div class="min-w-0">
                    <h3 class="text-sm font-semibold text-zinc-950">@Localizer["StepTwoTitle"]</h3>
                    <p class="mt-1 text-sm leading-6 text-zinc-600">@Localizer["StepTwoBody"]</p>
                </div>
            </div>
        </div>

        <div class="flex justify-end border-t border-zinc-100 px-6 py-4">
            <a asp-page="/Workspaces/Edit"
               @@click="sessionStorage.setItem('uncanny.onboardingHidden', '1'); visible = false"
               class="btn btn-primary rounded-lg">@Localizer["CtaCreateWorkspace"]</a>
        </div>
    </div>
</div>
