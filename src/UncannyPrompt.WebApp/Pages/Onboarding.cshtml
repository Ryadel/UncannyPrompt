@page
@model OnboardingModel
@{
    ViewData["Title"] = Localizer["PageTitle"];
}

<section class="app-page">
    <partial name="_AppPageHeader" model="@(new AppPageHeaderModel(Localizer["HeroTitle"].Value, new[] { Model.TenantName }))" />

    <div class="mx-auto max-w-4xl space-y-6 px-4 py-6 sm:px-6 lg:px-0">
        <article class="rounded-2xl border border-uncanny-200 bg-uncanny-50 p-6 shadow-sm">
            <h2 class="text-2xl font-bold text-zinc-950">@Localizer["WelcomeTitle"]</h2>
            <p class="mt-3 text-base leading-7 text-zinc-700">@Localizer["WelcomeBody"]</p>
        </article>

        <article class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
            <div class="flex items-start gap-4">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-zinc-950 text-sm font-bold text-white">1</span>
                <div>
                    <h2 class="text-xl font-bold text-zinc-950">@Localizer["StepOneTitle"]</h2>
                    <p class="mt-2 text-base leading-7 text-zinc-600">@Localizer["StepOneBody"]</p>
                </div>
            </div>
        </article>

        <article class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
            <div class="flex items-start gap-4">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-zinc-950 text-sm font-bold text-white">2</span>
                <div>
                    <h2 class="text-xl font-bold text-zinc-950">@Localizer["StepTwoTitle"]</h2>
                    <p class="mt-2 text-base leading-7 text-zinc-600">@Localizer["StepTwoBody"]</p>
                </div>
            </div>
        </article>

        <div class="rounded-2xl border border-dashed border-zinc-300 bg-white p-6 text-center shadow-sm">
            <p class="mx-auto max-w-2xl text-base leading-7 text-zinc-600">@Localizer["CallToActionBody"]</p>
            <a asp-page="/Workspaces" asp-fragment="workspace-create" class="btn btn-primary mt-6 rounded-lg">@Localizer["CreateFirstWorkspace"]</a>
        </div>
    </div>
</section>
