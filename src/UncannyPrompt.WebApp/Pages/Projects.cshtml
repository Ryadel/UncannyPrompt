@page
@model ProjectsModel
@{
    ViewData["Title"] = Localizer["PageTitle"];
}

<section class="app-page">
    <partial name="_AppPageHeader" model="@(new AppPageHeaderModel(
        Title: SharedLocalizer["Projects"].Value,
        KickerParts: new[] { Model.ScopeState.CurrentTenantName ?? SharedLocalizer["Tenant"].Value, Model.ScopeState.CurrentWorkspaceName ?? SharedLocalizer["Workspace"].Value },
        Action: Model.ScopeState.CurrentWorkspaceId is null ? null : new AppPageHeaderAction(SharedLocalizer["NewProject"].Value, "/Projects/Edit")))" />

    <div class="app-page-grid">
        <div class="app-page-main space-y-4 lg:col-span-2">
            @if (Model.ScopeState.CurrentWorkspaceId is null)
            {
                <partial name="_EmptyState" model="@(new EmptyStateModel(
                    Title: Localizer["EmptyNoWorkspaceTitle"].Value,
                    Description: Localizer["EmptyNoWorkspaceDescription"].Value,
                    PrimaryActionLabel: Localizer["EmptyNoWorkspaceAction"].Value,
                    PrimaryActionPage: "/Workspaces/Edit",
                    PrimaryActionFragment: null,
                    Icon: EmptyStateIcon.Lock,
                    Tone: EmptyStateTone.Blocker))" />
            }
            else if (Model.Projects.Count == 0)
            {
                <partial name="_EmptyState" model="@(new EmptyStateModel(
                    Title: Localizer["EmptyTitle"].Value,
                    Description: Localizer["EmptyDescription"].Value,
                    PrimaryActionLabel: Localizer["EmptyAction"].Value,
                    PrimaryActionPage: "/Projects/Edit",
                    PrimaryActionFragment: null,
                    Icon: EmptyStateIcon.Project))" />
            }
            else
            {
                @foreach (var project in Model.Projects)
                {
                        var promptCount = Model.PromptCountsByProject.GetValueOrDefault(project.Id);

                        <article class="group relative rounded-xl border border-zinc-200 bg-white p-5 shadow-sm transition hover:border-uncanny-300 hover:shadow-md">
                            <a class="absolute inset-0 z-10 rounded-xl focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-uncanny-600"
                               asp-page="/Prompts"
                               asp-route-tenantId="@Model.ScopeState.CurrentTenantId"
                               asp-route-workspaceId="@project.WorkspaceId"
                               asp-route-projectId="@project.Id"
                               aria-label="@Localizer["OpenPrompts", project.Name]"></a>

                            <div class="relative flex flex-wrap items-start justify-between gap-3">
                                <div>
                                    <h2 class="flex items-center gap-2 text-xl font-bold text-zinc-950 transition group-hover:text-uncanny-800">
                                        <span>@project.Name</span>
                                        <svg class="h-4 w-4 text-zinc-300 transition group-hover:translate-x-0.5 group-hover:text-uncanny-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
                                    </h2>
                                    @if (!string.IsNullOrWhiteSpace(project.Description))
                                    {
                                        <p class="mt-1 text-sm text-zinc-600">@project.Description</p>
                                    }
                                </div>
                                <div class="relative z-20 flex flex-wrap items-center justify-end gap-2">
                                    <span class="text-sm text-zinc-500">@Localizer["PromptCount", promptCount]</span>
                                    <a class="btn btn-ghost btn-sm gap-1.5 rounded-lg text-zinc-700" asp-page="/Projects/Edit" asp-route-id="@project.Id">
                                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                                        @SharedLocalizer["Edit"]
                                    </a>
                                    <form method="post" asp-page-handler="DeleteProject" asp-route-id="@project.Id">
                                        <button class="btn btn-ghost btn-sm gap-1.5 rounded-lg text-rose-700" type="submit">
                                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                                            @SharedLocalizer["Delete"]
                                        </button>
                                    </form>
                                </div>
                            </div>

                            <div class="relative z-20 mt-4 space-y-2 border-t border-zinc-100 pt-4">
                                <div class="flex items-center justify-between rounded-md border border-zinc-200 bg-zinc-50 px-3 py-2 text-sm font-semibold">
                                    <span>@SharedLocalizer["ProjectRoot"]</span>
                                    <a class="btn btn-outline btn-xs rounded-lg" asp-page="/Folders/Edit" asp-route-projectId="@project.Id">@SharedLocalizer["CreateFolder"]</a>
                                </div>
                                @foreach (var folder in Model.Folders.Where(x => x.ProjectId == project.Id && x.ParentFolderId is null))
                                {
                                    <div class="rounded-md border border-zinc-200 px-3 py-2">
                                        <div class="flex items-center justify-between gap-3">
                                            <span>@folder.Name</span>
                                            <div class="flex gap-2">
                                                <a class="btn btn-ghost btn-xs rounded-lg" asp-page="/Folders/Edit" asp-route-id="@folder.Id">@SharedLocalizer["Edit"]</a>
                                                <form method="post" asp-page-handler="DeleteFolder" asp-route-id="@folder.Id">
                                                    <button class="btn btn-ghost btn-xs rounded-lg text-rose-700" type="submit">@SharedLocalizer["Delete"]</button>
                                                </form>
                                            </div>
                                        </div>
                                        @foreach (var child in Model.Folders.Where(x => x.ParentFolderId == folder.Id))
                                        {
                                            <div class="ms-4 mt-2 flex items-center justify-between gap-3 rounded-md border border-zinc-200 bg-zinc-50 px-3 py-2 text-sm">
                                                <span>@child.Name</span>
                                                <div class="flex gap-2">
                                                    <a class="btn btn-ghost btn-xs rounded-lg" asp-page="/Folders/Edit" asp-route-id="@child.Id">@SharedLocalizer["Edit"]</a>
                                                    <form method="post" asp-page-handler="DeleteFolder" asp-route-id="@child.Id">
                                                        <button class="btn btn-ghost btn-xs rounded-lg text-rose-700" type="submit">@SharedLocalizer["Delete"]</button>
                                                    </form>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </article>
                    }
                }
            </div>
        </div>
    </section>
