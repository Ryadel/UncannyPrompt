@page "/p/{token}"
@model UncannyPrompt.WebApp.Pages.PublicPromptModel
@{
    ViewData["Title"] = Model.Prompt?.Title ?? Localizer["FallbackPageTitle"].Value;
}

@if (Model.Prompt is null)
{
    <section class="mx-auto max-w-2xl px-4 py-20">
        <h1 class="text-3xl font-bold text-zinc-950">@Localizer["UnavailableTitle"]</h1>
        <p class="mt-3 text-zinc-600">@Localizer["UnavailableBody"]</p>
    </section>
}
else
{
    <section class="mx-auto max-w-4xl px-4 py-12">
        <div class="space-y-4">
            <div class="flex flex-wrap gap-2">
                @foreach (var tag in Model.Prompt.Tags)
                {
                    <span class="badge badge-outline rounded-md">@tag</span>
                }
            </div>
            <h1 class="text-4xl font-bold text-zinc-950">@Model.Prompt.Title</h1>
            @if (!string.IsNullOrWhiteSpace(Model.Prompt.Summary))
            {
                <p class="text-lg text-zinc-600">@Model.Prompt.Summary</p>
            }
        </div>
        <pre class="mt-8 whitespace-pre-wrap rounded-lg border border-zinc-200 bg-white p-5 text-sm leading-7 text-zinc-900">@Model.Prompt.Content</pre>
    </section>
}
